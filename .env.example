# =====================================================================
# .env.example — variables d'environnement attendues par le projet maria
# =====================================================================
# Copier en `.env.local` (dev) et configurer côté Vercel pour preview/prod.
# Toutes les variables `NEXT_PUBLIC_*` sont inlinées au build — ne PAS
# y mettre de secret (utiliser des variables sans préfixe pour les
# secrets serveur, ex. SANITY_API_WRITE_TOKEN, RESEND_API_KEY).

# ---------------------------------------------------------------------
# Site (URL canonique)
# ---------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://maria.tech

# Mettre à `true` UNIQUEMENT en production une fois prêt à être indexé.
# En preview Vercel et en dev, laisser vide → robots.txt = disallow: /
# et X-Robots-Tag: noindex sur toutes les réponses.
NEXT_PUBLIC_ALLOW_INDEXING=

# ---------------------------------------------------------------------
# Sanity (CMS)
# ---------------------------------------------------------------------
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-04-19

# Token d'écriture Sanity — UNIQUEMENT pour les scripts (`scripts/*.mjs`).
# Ne JAMAIS exposer côté client. À récupérer dans Sanity → Settings → API.
SANITY_API_WRITE_TOKEN=

# ---------------------------------------------------------------------
# E-mails transactionnels (Resend)
# ---------------------------------------------------------------------
RESEND_API_KEY=

# ---------------------------------------------------------------------
# Prise de rendez-vous (Cal.com)
# ---------------------------------------------------------------------
# URL publique de l'event Cal.com (ex. https://cal.com/maria/echange-30min).
# Optionnel : si vide, le projet retombe sur la valeur stockée dans
# Sanity (parametresGlobaux.contact.calendlyUrl).
NEXT_PUBLIC_CALCOM_URL=

# ---------------------------------------------------------------------
# Marketing tags (Google Tag Manager)
# ---------------------------------------------------------------------
# Container GTM (format : GTM-XXXXXXXX). C'est le SEUL endroit côté
# code où l'on déclare un outil marketing — GA4 et autres tags sont
# configurés DANS l'interface GTM, pas en direct côté site.
#
# Sans Axeptio configuré, GTM ne se charge jamais. Sans GTM_ID,
# GtmLoader est no-op (utile pour le dev local sans config).
NEXT_PUBLIC_GTM_ID=

# ID de mesure GA4 (format : G-XXXXXXXXXX) — pour référence et
# documentation uniquement. PLUS UTILISÉ CÔTÉ CODE : GA4 est désormais
# déclenché via un tag GTM, pas directement par le site.
NEXT_PUBLIC_GA_ID=

# ---------------------------------------------------------------------
# Consentement RGPD (Axeptio)
# ---------------------------------------------------------------------
# clientId Axeptio (récupérable dans le dashboard Axeptio).
# Si vide, le bandeau de consentement n'est pas chargé, et GTM non plus.
# Axeptio gère NATIVEMENT Google Consent Mode v2 (vérifié en pré-prod).
NEXT_PUBLIC_AXEPTIO_CLIENT_ID=
# Version du projet Axeptio (optionnel, défaut : « maria-fr-EU »).
NEXT_PUBLIC_AXEPTIO_VERSION=
